{
  "expo": {
    "name": "Aether",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/aetherLogo.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/aetherLogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/aetherLogo.png",
      "bundleIdentifier": "com.av6sherlock.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/aetherLogo.png",
        "backgroundColor": "#0f172a"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.av6sherlock.mobile"
    },
    "web": {
      "favicon": "./assets/aetherLogo.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-notifications"
    ]
  }
}
